{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScoreAction",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "$ref": "./targets.json"
    },
    "payload": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "default": {}
    }
  },
  "required": ["kind", "target", "payload"]
}
